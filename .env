# ── Serveur ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/loranoeud

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────
# En production : mettre l'URL de votre app mobile ou laisser * pour React Native
CORS_ORIGIN=*
